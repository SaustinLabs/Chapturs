# Database
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-auth-secret-here"

# Google OAuth Configuration
# Get these from https://console.developers.google.com/
AUTH_GOOGLE_ID="your-google-client-id-here"
AUTH_GOOGLE_SECRET="your-google-client-secret-here"

# Legacy aliases (optional fallback)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="your-nextauth-secret-here"
# GOOGLE_CLIENT_ID="your-google-client-id-here"
# GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# Cloudflare R2 Configuration (Image Upload System)
# Get these from https://dash.cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID="your-r2-account-id-here"
R2_ACCESS_KEY_ID="your-r2-access-key-here"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key-here"
R2_BUCKET_NAME="chapturs-images"
R2_PUBLIC_URL="https://images.chapturs.com"  # or https://pub-{ACCOUNT_ID}.r2.dev

# Free Tier Settings
FREE_TIER_ENABLED="true"
FREE_TIER_STORAGE_GB="10"
FREE_TIER_OPERATIONS="1000000"

# Upload Limits (in MB)
MAX_PROFILE_SIZE_MB="3"
MAX_COVER_SIZE_MB="5"
MAX_FANART_SIZE_MB="8"
MAX_CHAPTER_SIZE_MB="6"

# Cleanup Settings
AUTO_CLEANUP_ENABLED="true"
CLEANUP_UNUSED_DAYS="30"
CLEANUP_REJECTED_DAYS="7"

# Alerts
STORAGE_WARNING_PERCENT="75"
STORAGE_CRITICAL_PERCENT="90"
ALERT_EMAIL="admin@chapturs.com"

# Optional: Additional environment variables
# NODE_ENV="development"

# Email Notifications (Resend)
# Get your free API key at https://resend.com — verify chapturs.com as your sending domain there.
# For production: add RESEND_API_KEY and EMAIL_FROM as GitHub Secrets (they sync to the VPS automatically on deploy).
# Leave unset to disable email notifications — the app will silently skip sending (safe for local dev).
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="Chapturs <notifications@chapturs.com>"

# Google AdSense (for ad monetization)
NEXT_PUBLIC_ADSENSE_PUB_ID="ca-pub-5320775955237091"
NEXT_PUBLIC_ADSENSE_SLOT_ID="your-ad-slot-id-here"

# Admin Access Bootstrap
# Set ADMIN_EMAIL to the email address of the site owner's account.
# Set ADMIN_BOOTSTRAP_PIN to a 4-digit number you choose.
# Visit /admin/bootstrap while signed in as that account, enter the PIN,
# then sign out and back in to activate the admin role.
# After your role is set you can remove or leave these set — they're only
# used by the one-time bootstrap flow; the role is stored in the DB.
ADMIN_EMAIL="your-email@example.com"
ADMIN_BOOTSTRAP_PIN="0000"

# Stripe (Premium Subscriptions)
# Create a product + recurring price at https://dashboard.stripe.com/products
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_ID="price_..."  # The monthly recurring price ID
STRIPE_WEBHOOK_SECRET="whsec_..."  # From Stripe Dashboard -> Webhooks

# OpenRouter (AI Quality Assessment, Translation, Reviews)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."

# LLM model overrides — set in GitHub Secrets to swap models without code changes.
# Defaults are shown. Any OpenRouter model slug works (see https://openrouter.ai/models).
# LLM_QA_MODEL="meta-llama/llama-3.3-70b-instruct"       # quality assessment scoring
# LLM_TRANSLATION_MODEL="meta-llama/llama-3.1-8b-instruct" # chapter/glossary translation
# LLM_REVIEW_MODEL="meta-llama/llama-3.1-8b-instruct"      # cumulative reader reviews

# Quality Assessment — shared secret for the queue / process endpoints (any random string)
# QA_PROCESSOR_SECRET="your-random-secret-here"
